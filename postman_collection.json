      "item": [
        {
          "name": "Step 1 — Verify Location (GPS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('location_token', pm.response.json().data.location_token);",
                  "  console.log('✅ location_token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": \"{{shop_id}}\",\n  \"latitude\": 51.5074,\n  \"longitude\": -0.1278\n}"
            },
